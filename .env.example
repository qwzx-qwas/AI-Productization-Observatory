# Copy this file to `.env` for local-only configuration.
# API 是隐私内容，务必不能泄漏。
# Never commit real API keys, tokens, or credentials to this public repository.

APO_CONFIG_DIR=configs
APO_SCHEMA_DIR=schemas
APO_FIXTURES_DIR=fixtures
APO_CANDIDATE_WORKSPACE_DIR=docs/candidate_prescreen_workspace
APO_GOLD_SET_STAGING_DIR=docs/gold_set_300_real_asset_staging
APO_RAW_STORE_DIR=.runtime/raw_store
APO_TASK_STORE_PATH=.runtime/task_store/tasks.json
APO_MART_OUTPUT_DIR=.runtime/marts
APO_LOG_LEVEL=INFO

# Sensitive API credentials: placeholders only. Replace locally in `.env`.
# GitHub remains the current-phase live source path for candidate prescreen.
GITHUB_TOKEN=your_github_token_here
# Reserved for future Product Hunt live integration or historical compatibility.
# Current Product Hunt fixture / replay flows do not require this token.
PRODUCT_HUNT_TOKEN=your_product_hunt_token_here

# Reserved local-only placeholders for future direct integrations.
OPENAI_API_KEY=your_api_key_here
SCRAPER_API_KEY=your_api_key_here

# Optional relay-LLM adapter settings for current GitHub live candidate prescreen runs.
APO_LLM_RELAY_BASE_URL=https://your-relay.example.com/v1/prescreen
APO_LLM_RELAY_TOKEN=your_relay_token_here
APO_LLM_RELAY_MODEL=your_model_name_here
APO_LLM_RELAY_TIMEOUT_SECONDS=30
APO_LLM_RELAY_CLIENT_VERSION=relay_candidate_prescreener_v1
