{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "review_packet",
  "type": "object",
  "required": [
    "target_summary",
    "issue_type",
    "current_auto_result",
    "related_evidence",
    "conflict_point",
    "recommended_action",
    "upstream_downstream_links"
  ],
  "properties": {
    "target_summary": {
      "type": "string",
      "minLength": 1
    },
    "issue_type": {
      "type": "string",
      "enum": [
        "entity_merge_uncertainty",
        "taxonomy_low_confidence",
        "taxonomy_conflict",
        "score_conflict",
        "suspicious_result"
      ]
    },
    "current_auto_result": {
      "type": "object",
      "minProperties": 1
    },
    "related_evidence": {
      "type": "array",
      "minItems": 1
    },
    "conflict_point": {
      "type": "string",
      "minLength": 1
    },
    "recommended_action": {
      "type": "string",
      "minLength": 1
    },
    "upstream_downstream_links": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": false
}
