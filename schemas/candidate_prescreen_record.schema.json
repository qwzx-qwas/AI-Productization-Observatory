{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apo.local/schemas/candidate_prescreen_record.schema.json",
  "title": "Candidate Prescreen Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_type",
    "document_version",
    "candidate_id",
    "candidate_batch_id",
    "created_at",
    "updated_at",
    "source",
    "source_id",
    "source_window",
    "time_field",
    "external_id",
    "canonical_url",
    "title",
    "summary",
    "raw_evidence_excerpt",
    "query_family",
    "query_slice_id",
    "selection_rule_version",
    "llm_prescreen",
    "whitelist_reason",
    "human_review_status",
    "human_review_note_template_key",
    "human_review_notes",
    "staging_handoff"
  ],
  "properties": {
    "document_type": {
      "const": "candidate_prescreen_record"
    },
    "document_version": {
      "const": "candidate_prescreen_v1"
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "sample_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "candidate_batch_id": {
      "type": "string",
      "minLength": 1
    },
    "analysis_run_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "enum": [
        "github",
        "product_hunt"
      ]
    },
    "source_id": {
      "enum": [
        "src_github",
        "src_product_hunt"
      ]
    },
    "source_window": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}\\.\\.\\d{4}-\\d{2}-\\d{2}$"
    },
    "time_field": {
      "enum": [
        "pushed_at",
        "published_at"
      ]
    },
    "external_id": {
      "type": "string",
      "minLength": 1
    },
    "canonical_url": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "raw_evidence_excerpt": {
      "type": "string"
    },
    "query_family": {
      "type": [
        "string",
        "null"
      ]
    },
    "query_slice_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "selection_rule_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "discovery_mode",
        "selection_basis",
        "source_item_ref"
      ],
      "properties": {
        "discovery_mode": {
          "enum": [
            "fixture",
            "live"
          ]
        },
        "selection_basis": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "window_start",
            "window_end",
            "query_family",
            "query_slice_id",
            "selection_rule_version"
          ],
          "properties": {
            "window_start": {
              "type": "string",
              "minLength": 1
            },
            "window_end": {
              "type": "string",
              "minLength": 1
            },
            "query_family": {
              "type": [
                "string",
                "null"
              ]
            },
            "query_slice_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "selection_rule_version": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "source_item_ref": {
          "$ref": "#/$defs/nonEmptyReference"
        }
      }
    },
    "llm_prescreen": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "in_observatory_scope",
        "reason",
        "decision_snapshot",
        "scope_boundary_note",
        "source_evidence_summary",
        "evidence_anchors",
        "review_focus_points",
        "uncertainty_points",
        "recommend_candidate_pool",
        "recommended_action",
        "confidence_summary",
        "handoff_readiness_hint",
        "persona_candidates",
        "taxonomy_hints",
        "assessment_hints",
        "channel_metadata",
        "error_type",
        "error_message"
      ],
      "properties": {
        "status": {
          "enum": [
            "succeeded",
            "failed"
          ]
        },
        "in_observatory_scope": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "decision_snapshot": {
          "type": [
            "string",
            "null"
          ]
        },
        "scope_boundary_note": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_evidence_summary": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_anchors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceAnchor"
          },
          "maxItems": 5
        },
        "review_focus_points": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 4
        },
        "uncertainty_points": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommend_candidate_pool": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "recommended_action": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "reject",
            "hold",
            "candidate_pool",
            "whitelist_candidate",
            null
          ]
        },
        "confidence_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "scope_confidence",
            "taxonomy_confidence",
            "persona_confidence"
          ],
          "properties": {
            "scope_confidence": {
              "$ref": "#/$defs/nullableConfidenceLevel"
            },
            "taxonomy_confidence": {
              "$ref": "#/$defs/nullableConfidenceLevel"
            },
            "persona_confidence": {
              "$ref": "#/$defs/nullableConfidenceLevel"
            }
          }
        },
        "handoff_readiness_hint": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "suggested_action",
            "rationale"
          ],
          "properties": {
            "suggested_action": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "reject",
                "hold",
                "candidate_pool",
                "whitelist_candidate",
                null
              ]
            },
            "rationale": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "persona_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/personaCandidate"
          },
          "maxItems": 3
        },
        "taxonomy_hints": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "primary_category_code",
            "secondary_category_code",
            "primary_persona_code",
            "delivery_form_code",
            "main_category_candidate",
            "adjacent_category_candidate",
            "adjacent_category_rejected_reason"
          ],
          "properties": {
            "primary_category_code": {
              "type": [
                "string",
                "null"
              ]
            },
            "secondary_category_code": {
              "type": [
                "string",
                "null"
              ]
            },
            "primary_persona_code": {
              "type": [
                "string",
                "null"
              ]
            },
            "delivery_form_code": {
              "type": [
                "string",
                "null"
              ]
            },
            "main_category_candidate": {
              "$ref": "#/$defs/categoryCandidate"
            },
            "adjacent_category_candidate": {
              "$ref": "#/$defs/adjacentCategoryCandidate"
            },
            "adjacent_category_rejected_reason": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "assessment_hints": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "evidence_strength",
            "build_evidence_band",
            "need_clarity_band",
            "unresolved_risk"
          ],
          "properties": {
            "evidence_strength": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "low",
                "medium",
                "high",
                null
              ]
            },
            "build_evidence_band": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "low",
                "medium",
                "high",
                null
              ]
            },
            "need_clarity_band": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "low",
                "medium",
                "high",
                null
              ]
            },
            "unresolved_risk": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "low",
                "medium",
                "high",
                null
              ]
            }
          }
        },
        "channel_metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "prompt_version",
            "routing_version",
            "relay_client_version",
            "model",
            "transport"
          ],
          "properties": {
            "prompt_version": {
              "type": [
                "string",
                "null"
              ]
            },
            "routing_version": {
              "type": [
                "string",
                "null"
              ]
            },
            "relay_client_version": {
              "type": [
                "string",
                "null"
              ]
            },
            "model": {
              "type": [
                "string",
                "null"
              ]
            },
            "transport": {
              "type": "string",
              "minLength": 1
            },
            "request_id": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "error_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "error_message": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "whitelist_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "human_review_status": {
      "enum": [
        "pending_first_pass",
        "approved_for_staging",
        "rejected_after_human_review",
        "on_hold"
      ]
    },
    "human_review_note_template_key": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "approved",
        "hold",
        "rejected",
        null
      ]
    },
    "human_review_notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "human_reviewed_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "staging_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "staging_document_path",
        "sample_slot_id",
        "sample_id",
        "blocking_items",
        "last_attempted_at"
      ],
      "properties": {
        "status": {
          "enum": [
            "not_started",
            "blocked",
            "written"
          ]
        },
        "staging_document_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "sample_slot_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "sample_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "blocking_items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "last_attempted_at": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  },
  "$defs": {
    "nullableConfidenceLevel": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "low",
        "medium",
        "high",
        null
      ]
    },
    "evidenceAnchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "anchor_rank",
        "evidence_text",
        "evidence_source_field",
        "why_it_matters"
      ],
      "properties": {
        "anchor_rank": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "evidence_text": {
          "type": "string",
          "minLength": 1
        },
        "evidence_source_field": {
          "type": "string",
          "minLength": 1
        },
        "why_it_matters": {
          "type": "string",
          "minLength": 1
        },
        "applies_to": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "scope",
              "taxonomy",
              "persona",
              "recommended_action"
            ]
          }
        }
      }
    },
    "categoryCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "category_code",
        "rationale",
        "supporting_evidence_anchors"
      ],
      "properties": {
        "category_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "rationale": {
          "type": [
            "string",
            "null"
          ]
        },
        "supporting_evidence_anchors": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          }
        }
      }
    },
    "adjacentCategoryCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "category_code",
        "rationale_for_similarity",
        "supporting_evidence_anchors"
      ],
      "properties": {
        "category_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "rationale_for_similarity": {
          "type": [
            "string",
            "null"
          ]
        },
        "supporting_evidence_anchors": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          }
        }
      }
    },
    "personaCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "persona_code",
        "confidence_rank",
        "rationale",
        "supporting_evidence_anchors"
      ],
      "properties": {
        "persona_code": {
          "type": "string",
          "minLength": 1
        },
        "confidence_rank": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "supporting_evidence_anchors": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          }
        }
      }
    },
    "nonEmptyReference": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "null"
        ]
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "llm_prescreen": {
            "properties": {
              "status": {
                "const": "succeeded"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "llm_prescreen": {
            "properties": {
              "channel_metadata": {
                "properties": {
                  "prompt_version": {
                    "type": "string",
                    "minLength": 1
                  },
                  "routing_version": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
